def binary_search(arr: list[int], target) -> int:
    '''
    Return the index of the target if found in array, else return -1
    '''
    l, r = 0, len(arr) - 1
    while l < r:
        mid = (l + r) // 2
        if target == arr[mid]:
            return mid
        elif target > arr[mid]:
            l = mid + 1
        else:
            r = mid - 1
    return -1

