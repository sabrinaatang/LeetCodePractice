def lower_bound(arr, target) -> int:
    '''
    Find index where target is located if found, else find location it would be inserted
    Lower bound: first index ≥ target Upper bound: first index > target
    Returns the index of the first element greater than the target.
    '''
    l, r = 0, len(arr)
    while l < r:
        mid = (l + r) // 2
        if target > arr[mid]:
            l = mid + 1
        else:
            r = mid
    return l

